# ── PostgreSQL connection ──────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/todo_db"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-256-bit-secret"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
